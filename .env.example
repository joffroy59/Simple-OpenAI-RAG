OPENAI_API_KEY=your_openai_api_key_here

# LLM provider: openai | ollama
LLM_PROVIDER=openai

# Model to use
# OpenAI examples: gpt-3.5-turbo, gpt-4o
# Ollama examples: llama3, mistral, phi3
LLM_MODEL=gpt-3.5-turbo

# Ollama base URL (only needed when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# PDF parsing language(s) for Unstructured (ISO/Tesseract codes, comma-separated)
# Example: fra or fra,eng
UNSTRUCTURED_LANGUAGES=fra

# Retrieval settings for better completeness on list questions
RAG_RETRIEVER_SEARCH_TYPE=mmr
RAG_RETRIEVER_K=12
RAG_RETRIEVER_FETCH_K=40